# Supabase 配置 (必填)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_FORM_ID=your_form_id
VITE_APP_ID=your_app_id

# 站点基础配置 (可选，优先级高于数据库配置)
VITE_SITE_TITLE=图片视频赏析
VITE_SITE_LOGO=
VITE_SITE_DESCRIPTION=

# 访问控制 (可选，优先级高于数据库配置)
# 是否仅限微信访问 (true/false)
VITE_WECHAT_ONLY=false
# 是否禁止微信访问 (true/false)
VITE_WECHAT_FORBIDDEN=false
# 是否强制登录 (true/false)
VITE_FORCE_LOGIN=false
# 注册模式 (public/invite)
VITE_REGISTER_MODE=public
# 匿名用户浏览限制 (数字，0表示无限制)
VITE_ANONYMOUS_VIEW_LIMIT=0

# 水印配置 (可选，优先级高于数据库配置)
# 是否启用水印 (true/false)
VITE_WATERMARK_ENABLED=false

# 积分配置 (可选，优先级高于数据库配置)
# 签到奖励积分
VITE_CHECK_IN_POINTS=10

# 配置优先级说明：
# 1. .env 文件中的配置优先级最高
# 2. 如果 .env 中未配置，则使用数据库中的配置
# 3. 如果数据库中也未配置，则使用代码中的默认值
