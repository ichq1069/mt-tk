{
  "rewrites": [
    {
      "source": "/((?!assets/|favicon.png|manifest.webmanifest|registerSW.js|sw.ts|public/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
